#!/usr/bin/env sh

RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

printf "\n%b  рҹ“қ  Validating commit message...%b\n\n" "${BOLD}" "${RESET}"

if ! npx --no -- commitlint --edit "$1" > /tmp/husky_commitmsg.log 2>&1; then
  printf "%b" "${RED}"
  cat /tmp/husky_commitmsg.log
  printf "%b" "${RESET}"

  printf "\n%bв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ%b\n" "${RED}${BOLD}" "${RESET}"
  printf "%bв”Ӯ              рҹҡ«  Commit blocked                  в”Ӯ%b\n" "${RED}${BOLD}" "${RESET}"
  printf "%bв”Ӯ                                                  в”Ӯ%b\n" "${RED}${BOLD}" "${RESET}"
  printf "%bв”Ӯ  Commit message does not follow convention.      в”Ӯ%b\n" "${RED}${BOLD}" "${RESET}"
  printf "%bв”Ӯ                                                  в”Ӯ%b\n" "${RED}${BOLD}" "${RESET}"
  printf "%bв”Ӯ  Format:  type(scope): subject                   в”Ӯ%b\n" "${RED}${BOLD}" "${RESET}"
  printf "%bв”Ӯ                                                  в”Ӯ%b\n" "${RED}${BOLD}" "${RESET}"
  printf "%bв”Ӯ  Examples:                                       в”Ӯ%b\n" "${RED}${BOLD}" "${RESET}"
  printf "%bв”Ӯ    feat(auth): add login with google             в”Ӯ%b\n" "${DIM}" "${RESET}"
  printf "%bв”Ӯ    fix(tours): correct price display format      в”Ӯ%b\n" "${DIM}" "${RESET}"
  printf "%bв”Ӯ    chore: update dependencies                    в”Ӯ%b\n" "${DIM}" "${RESET}"
  printf "%bв”Ӯ    docs: add api endpoint documentation          в”Ӯ%b\n" "${DIM}" "${RESET}"
  printf "%bв”Ӯ                                                  в”Ӯ%b\n" "${RED}${BOLD}" "${RESET}"
  printf "%bв”Ӯ  Valid types:                                    в”Ӯ%b\n" "${RED}${BOLD}" "${RESET}"
  printf "%bв”Ӯ  feat fix docs style refactor perf              в”Ӯ%b\n" "${CYAN}" "${RESET}"
  printf "%bв”Ӯ  test build ci chore revert                     в”Ӯ%b\n" "${CYAN}" "${RESET}"
  printf "%bв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ%b\n\n" "${RED}${BOLD}" "${RESET}"
  exit 1
fi

printf "%b  вң”  Commit message is valid.%b\n\n" "${GREEN}${BOLD}" "${RESET}"
